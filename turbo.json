{
  "$schema": "https://turbo.build",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**"]
    },
    "build:image": {
      "dependsOn": ["^build:image"],
      "inputs": ["**/*", "!**/node_modules/**"],
      "outputs": []
    },
    "deploy": {
      "dependsOn": ["build:image"]
    },
    "test": {
      "dependsOn": [],
      "outputs": []
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "cache": true
    }
  }
}
