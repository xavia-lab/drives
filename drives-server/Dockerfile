# Stage 1: Pruning
FROM node:24-alpine AS pruner
RUN apk add --no-cache libc6-compat
WORKDIR /app
# Enable Corepack; it automatically matches your package.json version downstream
RUN corepack enable
COPY . .
# Run global commands via npx to match your workspace engines
RUN npx turbo prune --scope=drives-server --docker

# Stage 2: Installer
FROM node:24-alpine AS installer
RUN apk add --no-cache libc6-compat
WORKDIR /app
RUN corepack enable

# Copy workspace layout generated by the pruner
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=pruner /app/out/pnpm-workspace.yaml ./pnpm-workspace.yaml

# Corepack checks package.json dynamically and matches your pnpm version here
RUN pnpm install --frozen-lockfile

# Stage 3: Builder
FROM node:24-alpine AS builder
WORKDIR /app
RUN corepack enable
COPY --from=pruner /app/out/full/ .
COPY --from=installer /app/ .
RUN pnpm turbo run build --filter=drives-server

# Stage 4: Production Runner
FROM node:24-alpine AS runner

ARG UID=1010
ARG GID=1010
ARG PORT=5000
ENV PORT=${PORT}

WORKDIR /app

# Enable Corepack so pnpm and dlx are globally available at runtime
RUN corepack enable

RUN addgroup -g ${GID} -S nodejs && \
    adduser -S -u ${UID} -G nodejs nestjs

# Set directory permissions for the non-root user
RUN chown nestjs:nodejs /app

# Copy the compiled monorepo layout into the runner context
COPY --from=builder --chown=nestjs:nodejs /app .

# Move execution context directly into the backend server directory scope
WORKDIR /app/drives-server

# FIXED ENTRYPOINT SCRIPT:
# We use pnpm dlx to run sequelize-cli independently of local node_modules tracking.
# We pass --yes to ensure it automatically approves execution without an interactive TTY.
RUN echo '#!/bin/sh' > ./entrypoint.sh && \
    echo 'echo "--- STARTING ENTRYPOINT SCRIPT ---"' >> ./entrypoint.sh && \
    echo 'echo "Step 1/3: Running migrations..."' >> ./entrypoint.sh && \
    echo 'pnpm dlx --yes sequelize-cli db:migrate' >> ./entrypoint.sh && \
    echo 'echo "Step 2/3: Running seeds..."' >> ./entrypoint.sh && \
    echo 'pnpm dlx --yes sequelize-cli db:seed:all' >> ./entrypoint.sh && \
    echo 'echo "Step 3/3: Starting NestJS app..."' >> ./entrypoint.sh && \
    echo 'node dist/src/main.js' >> ./entrypoint.sh && \
    chmod +x ./entrypoint.sh && \
    chown nestjs:nodejs ./entrypoint.sh

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:${PORT}/system/status || exit 1

USER nestjs

EXPOSE ${PORT}

ENTRYPOINT ["./entrypoint.sh"]
